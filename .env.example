# Copy this file to .env and fill in your real keys for local testing.
# Never commit .env — it's gitignored.

TELEGRAM_BOT_TOKEN=paste-token-from-botfather

# At least ONE of the LLM keys below must be set. More = better fallback.
#
# Text cascade:  Sarvam 105B -> Gemini 2.5 Flash -> Gemma 4 31B (OpenRouter) -> Llama 3.3 70B (Groq)
# Voice cascade: Sarvam Saaras v3 -> Gemini 2.5 Flash multimodal -> Groq Whisper Large v3

SARVAM_API_KEY=paste-key-from-dashboard.sarvam.ai
GEMINI_API_KEY=paste-key-from-aistudio.google.com
OPENROUTER_API_KEY=paste-key-from-openrouter.ai/settings/keys
GROQ_API_KEY=paste-key-from-console.groq.com

# Optional — most hosts set PORT automatically. Default is 8080.
# PORT=8080
